{
  "manifest_version": 3,
  "name": "SocialMate — Save to Drafts",
  "version": "1.0.0",
  "description": "Save any web content to SocialMate drafts with one click",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://socialmate.studio/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
